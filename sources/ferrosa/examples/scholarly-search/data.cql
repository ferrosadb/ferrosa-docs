INSERT INTO paper (paper_id, title, abstract, year, venue, embedding) VALUES (9, 'The Log-Structured Merge Tree', 'The LSM tree buffers writes in memory and flushes sorted runs to disk, merging them in the background. It trades read amplification for high write throughput, the basis of modern key-value storage engines.', 2016, 'VLDB', [0.036945, 0.008060, -0.051123, -0.019842, -0.008707, 0.001548, -0.015967, 0.020542, 0.012050, 0.036940, -0.087234, -0.044918, -0.034773, 0.031877, -0.039994, 0.010686, -0.029685, 0.020137, -0.074801, -0.013927, 0.035615, 0.058147, -0.025658, -0.044762, -0.005541, -0.010768, 0.014620, 0.000943, 0.098173, 0.041167, 0.017441, -0.060264, 0.050198, 0.063886, -0.034815, 0.001540, -0.024577, -0.036969, -0.014081, -0.079069, -0.003031, 0.019331, -0.004458, -0.011408, 0.040969, 0.048048, -0.023816, -0.017015, 0.053488, 0.001245, 0.034637, 0.048103, -0.001609, -0.014604, 0.009505, 0.002682, -0.019772, -0.046659, 0.053637, -0.021371, 0.021246, -0.030698, 0.037908, 0.033921, 0.015617, 0.069779, 0.052251, -0.044070, -0.061416, 0.051753, 0.013856, -0.008841, 0.097446, -0.030922, -0.058965, -0.032395, 0.021820, 0.078536, 0.033180, -0.002107, -0.024963, 0.048120, 0.001680, -0.010038, -0.057800, 0.009457, 0.018383, 0.032549, -0.052536, -0.020456, -0.002733, -0.050469, 0.028650, 0.012270, 0.012829, -0.004093, -0.024117, -0.004948, -0.001440, 0.070684, -0.029248, 0.062091, -0.057766, -0.008499, -0.076015, 0.005432, 0.009944, -0.027558, 0.003604, -0.001504, -0.062959, 0.003329, -0.051188, 0.029668, 0.003147, -0.010881, 0.073061, -0.029722, 0.025888, 0.058394, 0.103026, 0.006126, 0.008355, 0.103069, 0.017244, -0.009320, -0.074517, 0.046872, -0.006598, 0.014994, -0.056795, 0.020713, -0.007143, -0.032477, -0.039155, -0.011112, 0.018782, -0.034077, -0.008275, -0.072702, 0.021378, 0.052250, 0.010145, -0.004734, -0.033362, 0.008702, 0.009332, 0.061704, -0.048366, 0.017565, -0.021728, -0.010308, -0.013717, 0.005105, 0.009108, -0.006046, -0.046754, -0.015840, -0