INSERT INTO paper (paper_id, title, abstract, year, venue, embedding) VALUES (11, 'Disaggregated Storage on Cloud Object Stores', 'We move durable storage to a cloud object store and keep local disk as an ephemeral cache, writing behind asynchronously. Compute scales independently of data, eliminating rebalancing on cluster growth.', 2023, 'NSDI', [-0.041458, -0.050000, 0.008273, -0.045881, -0.026570, -0.049847, -0.015277, -0.010639, 0.000513, -0.010076, -0.016850, -0.016665, -0.009503, 0.027411, -0.040409, 0.021336, -0.060724, -0.029396, -0.000234, 0.027278, -0.071882, -0.002187, -0.001604, -0.077361, 0.019504, -0.015794, 0.004384, 0.001959, 0.104964, 0.038261, 0.001658, -0.015883, -0.040023, 0.059282, -0.033110, 0.005044, -0.034903, -0.036114, -0.025979, -0.015268, -0.037848, 0.070655, 0.005925, 0.015680, 0.007830, -0.001956, -0.014608, -0.007211, -0.035140, 0.050027, -0.019385, -0.015138, 0.035579, -0.049885, -0.003001, -0.002013, -0.001417, -0.016610, 0.028084, 0.063713, 0.034623, 0.003910, 0.028685, 0.043366, -0.017572, 0.061813, 0.007686, -0.036432, -0.078146, -0.039302, -0.050176, 0.038429, 0.078508, -0.047936, -0.063807, -0.002599, -0.040969, 0.048598, 0.033965, -0.024301, 0.032854, -0.040864, -0.004215, 0.046420, -0.048486, 0.024257, 0.001523, 0.085813, -0.018768, 0.001921, -0.013584, -0.020286, -0.032493, 0.044351, -0.036304, 0.035395, -0.070146, 0.041664, -0.036733, 0.047314, -0.004644, 0.013010, -0.009208, -0.005389, -0.066898, -0.033188, 0.035316, -0.030998, -0.001013, -0.007613, -0.060944, -0.039958, -0.052071, 0.010641, -0.046778, -0.025363, 0.055826, -0.060068, 0.037365, 0.029587, 0.015778, 0.015852, -0.002347, 0.018320, 0.030490, 0.035823, -0.048790, -0.016742, -0.022132, 0.012931, -0.028479, 0.000292, -0.033278, -0.023618, 0.011677, -0.030200, 0.044281, -0.054554, -0.061005, -0.021105, 0.016594, 0.031681, -0.008127, 0.013620, -0.040380, 0.009642, -0.042156, 0.042082, -0.037612, -0.034672, -0.014851, 0.003308, -0.027564, 0.056198, 0.012063, 0.053272