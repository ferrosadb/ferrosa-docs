INSERT INTO paper (paper_id, title, abstract, year, venue, embedding) VALUES (3, 'Accord: Strict-Serializable Distributed Transactions', 'Accord is a leaderless protocol for multi-partition transactions that guarantees strict serializability. It orders conflicting transactions with hybrid logical clocks and a fast-path quorum, avoiding dedicated coordinators.', 2023, 'SIGMOD', [0.040983, -0.003709, 0.029655, 0.024193, -0.000972, -0.035364, -0.050812, 0.005402, -0.011780, 0.056189, -0.022448, -0.053008, -0.023196, -0.026886, -0.009103, -0.028681, -0.050089, -0.058249, 0.034884, 0.018241, 0.007885, 0.021936, 0.019347, 0.011446, 0.003921, 0.085885, -0.028965, -0.000349, 0.032727, 0.027651, 0.038886, -0.039735, -0.006962, 0.070555, -0.037492, -0.042043, -0.002025, -0.042612, 0.040387, -0.011206, -0.012712, -0.009876, 0.011874, 0.016941, -0.014112, 0.059466, -0.028779, 0.013715, -0.003589, 0.053464, 0.010051, -0.014949, 0.022367, 0.025333, -0.022621, -0.046533, 0.011525, -0.051958, 0.025790, -0.028918, -0.029812, 0.001271, 0.044760, 0.040177, -0.039841, 0.041872, 0.019241, -0.020869, -0.093674, -0.015230, -0.050973, 0.017359, 0.073841, -0.024402, -0.082213, 0.028558, -0.014966, 0.019858, 0.021661, -0.043223, -0.006887, 0.051651, -0.013643, 0.061510, -0.054655, -0.000955, 0.000410, 0.053625, -0.093810, 0.002663, 0.049830, -0.066905, 0.039640, 0.007578, 0.062464, -0.027002, -0.076492, 0.033854, -0.033856, 0.023430, -0.005867, -0.027698, 0.014599, -0.019629, -0.000525, 0.025460, 0.014414, -0.033986, 0.036198, 0.015795, -0.075278, -0.005946, -0.033198, -0.030388, 0.015395, 0.007451, 0.049105, -0.019851, 0.019317, -0.031310, -0.004024, 0.025709, 0.044299, 0.100563, 0.000190, 0.039514, -0.011247, 0.014807, -0.017320, 0.019167, 0.011174, 0.031271, 0.048635, 0.043824, 0.027569, -0.013842, 0.080984, -0.019887, -0.041014, 0.011088, 0.024286, 0.006185, 0.009488, 0.013772, -0.001012, 0.022273, -0.044912, 0.048435, -0.031595, 0.026374, -0.069862, 0.031378, -0.074238, 0.017667, -0.039